# App
APP_ENV=development
APP_SECRET_KEY=generate-with-openssl-rand-hex-32
APP_URL=https://frenzpay.co
API_URL=https://api.frenzpay.co

# Database
DATABASE_URL=postgresql+asyncpg://frenzpay:frenzpay@localhost:5432/frenzpay
REDIS_URL=redis://localhost:6379/0

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=generate-64-char-random
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

# PII Encryption — generate with: python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY=generate-32-byte-base64

# Graph (payment rails)
GRAPH_API_KEY=
GRAPH_API_URL=https://api.graph.finance
GRAPH_WEBHOOK_SECRET=

# Dojah (KYC)
DOJAH_APP_ID=
DOJAH_PUBLIC_KEY=
DOJAH_PRIVATE_KEY=
DOJAH_WEBHOOK_SECRET=

# Termii (SMS)
TERMII_API_KEY=
TERMII_SENDER_ID=FrenzPay

# Resend (email)
RESEND_API_KEY=
FROM_EMAIL=hello@frenzpay.co

# Monitoring
SENTRY_DSN=

# Alerts
ADMIN_ALERT_TELEGRAM_BOT_TOKEN=
ADMIN_ALERT_CHAT_ID=

# CORS
CORS_ORIGINS=["http://localhost:3000","https://frenzpay.co"]
