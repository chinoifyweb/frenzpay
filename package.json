{
  "name": "frenzpay",
  "private": true,
  "version": "0.1.0",
  "description": "FrenzPay â€” cross-border payments for the African diaspora",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @frenzpay/web dev",
    "dev:admin": "pnpm --filter @frenzpay/admin dev",
    "dev:workers": "pnpm --filter @frenzpay/workers dev",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "pnpm -r test",
    "test:unit": "pnpm -r test:unit",
    "db:generate": "pnpm --filter @frenzpay/db generate",
    "db:migrate": "pnpm --filter @frenzpay/db migrate",
    "db:seed": "pnpm --filter @frenzpay/db seed",
    "db:studio": "pnpm --filter @frenzpay/db studio",
    "prepare": "husky",
    "start:prod": "pm2 start ecosystem.config.js",
    "logs": "pm2 logs frenzpay-web",
    "stop": "pm2 stop ecosystem.config.js",
    "reload": "pm2 reload ecosystem.config.js --update-env",
    "deploy:local": "bash scripts/deploy.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "@prisma/client",
      "@prisma/engines",
      "argon2",
      "esbuild",
      "msgpackr-extract",
      "prisma",
      "sharp",
      "@node-rs/argon2"
    ]
  }
}