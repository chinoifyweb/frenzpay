# ════════════════════════════════════════════════════════════════════════════════
# FrenzPay — Environment Variables
# Copy this to .env.local for development. NEVER commit .env.local or .env.production.
# Production secrets live in Infisical (see infra/cyberpanel/08-kms.sh).
# ════════════════════════════════════════════════════════════════════════════════

# ── Core ────────────────────────────────────────────────────────────────────────
NODE_ENV=development
SERVICE_NAME=frenzpay-web
APP_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
LOG_LEVEL=debug
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=FrenzPay

# ── Database ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://frenzpay_app:your_password@localhost:5432/frenzpay_v3?sslmode=require
DIRECT_URL=postgresql://frenzpay_app:your_password@localhost:5432/frenzpay_v3?sslmode=require

# ── Redis ────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:your_redis_password@127.0.0.1:6379

# ── KMS / Envelope Encryption (Infisical self-hosted in production) ───────────────
INFISICAL_HOST=https://infisical.internal.frenzpay.co
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=
INFISICAL_PROJECT_ID=
INFISICAL_ENVIRONMENT=development

# Current KEK version — bump to "v2" when rotating keys
KEK_KEY_ID=v1
# 32 bytes base64. Generate: openssl rand -base64 32
KEK=REPLACE_WITH_32_BYTE_BASE64_KEY_FOR_DEV
# Separate key for blind indexes (BVN, NIN, phone lookups)
BLIND_INDEX_KEY=REPLACE_WITH_BLIND_INDEX_KEY_FOR_DEV
ENCRYPTION_KEY=REPLACE_WITH_32_BYTE_BASE64_KEY_FOR_DEV

# ── Session / Security ────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
SESSION_SECRET=REPLACE_WITH_SESSION_SECRET
PASSKEY_RP_ID=localhost
PASSKEY_RP_NAME=FrenzPay

# ── Bridge (USD Virtual Accounts + Virtual Cards) ──────────────────────────────────
BRIDGE_API_KEY=
BRIDGE_API_URL=https://api.bridge.xyz
BRIDGE_WEBHOOK_PUBLIC_KEY=

# ── Flutterwave (NGN Payouts) ──────────────────────────────────────────────────────
FLW_PUBLIC_KEY=FLWPUBK_TEST-
FLW_SECRET_KEY=FLWSECK_TEST-
FLW_ENCRYPTION_KEY=
FLW_WEBHOOK_SECRET=

# ── Dojah (KYC: BVN + Liveness) ───────────────────────────────────────────────────
DOJAH_APP_ID=
DOJAH_PRIVATE_KEY=
DOJAH_PUBLIC_KEY=
DOJAH_WEBHOOK_SECRET=

# ── SMS ───────────────────────────────────────────────────────────────────────────
TERMII_API_KEY=
TERMII_SENDER_ID=FrenzPay
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=+1XXXXXXXXXX

# ── Email ─────────────────────────────────────────────────────────────────────────
POSTMARK_SERVER_TOKEN=
EMAIL_FROM=no-reply@frenzpay.co
SMTP_HOST=mailserver.purelymail.com
SMTP_PORT=587
SMTP_USERNAME=noreply@frenzpay.co
SMTP_PASSWORD=
PURELYMAIL_API_KEY=

# ── CAPTCHA (Cloudflare Turnstile) ────────────────────────────────────────────────
# Dev always-pass keys: https://developers.cloudflare.com/turnstile/reference/testing/
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# ── Fraud / IP Intelligence ────────────────────────────────────────────────────────
IPQS_API_KEY=
MAXMIND_LICENSE_KEY=

# ── Observability ─────────────────────────────────────────────────────────────────
SENTRY_DSN=
LOKI_URL=http://localhost:3100
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ── Web Push (VAPID) ──────────────────────────────────────────────────────────────
# Generate: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:security@frenzpay.co

# ── Admin Allowlist ────────────────────────────────────────────────────────────────
ADMIN_IP_ALLOWLIST=127.0.0.1/32

# ── Yellow Card (African on/off ramp) ─────────────────────────────────────────────
YELLOWCARD_API_KEY=
YELLOWCARD_SECRET_KEY=
YELLOWCARD_WEBHOOK_SECRET=
YELLOWCARD_BASE_URL=https://api.yellowcard.io

# ── Hetzner deployment ────────────────────────────────────────────────────────────
# These are read on the server only (via /home/frenzpay/shared/.env.production).
# Keep them out of local dev — they assume localhost services on the production box.

# Cron worker
CRON_SECRET=                                  # shared secret for /api/cron/* endpoints

# Object storage (MinIO on same box as the Node process)
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_KYC=frenzpay-kyc
S3_BUCKET_AUDIT=frenzpay-audit

# Backups
B2_REMOTE=b2:frenzpay-backups                 # rclone remote name (configure rclone once)

# Sanctions screening
OPENSANCTIONS_DATA_URL=https://data.opensanctions.org/datasets/latest/default/entities.ftm.json
