{
  "name": "@frenzpay/providers",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./bridge": {
      "types": "./dist/bridge.d.ts",
      "default": "./src/bridge.ts"
    },
    "./bridge-cards": {
      "types": "./dist/bridge-cards.d.ts",
      "default": "./src/bridge-cards.ts"
    },
    "./graph": {
      "types": "./dist/graph.d.ts",
      "default": "./src/graph.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  }
}
