{
  "name": "@frenzpay/auth",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./session": {
      "types": "./dist/session.d.ts",
      "default": "./src/session.ts"
    },
    "./rate-limit": {
      "types": "./dist/rate-limit.d.ts",
      "default": "./src/rate-limit.ts"
    },
    "./totp": {
      "types": "./dist/totp.d.ts",
      "default": "./src/totp.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "ioredis": "^5.10.1",
    "iron-session": "^8.0.4",
    "otpauth": "^9.5.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  }
}
